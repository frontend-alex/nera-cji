@model RegisterViewModel

@{
    ViewData["Title"] = "NERA | Register";
    Layout = "~/Views/Shared/Layouts/_LayoutAuth.cshtml";
}

<div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">
    <div class="flex items-center justify-center">
        <div class="flex flex-col gap-10 p-5 max-w-[520px]">
            <h1 class="text-4xl font-medium text-center">
                Hi! Welcome to Nera Event Management System.
            </h1>
            <p class="text-center text-stone-500">
                Use the Auth0 Universal Login experience to create your account and start planning events faster.
            </p>
            <form asp-action="Register" method="post" class="flex flex-col gap-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <button type="submit" class="btn-fill-primary">
                    Sign up with Auth0
                </button>
                <span class="text-center text-stone-400">
                    Already have an account?
                    <a asp-action="Login"
                       class="ml-2 underline font-medium text-black"
                       asp-route-returnUrl="@(Model.ReturnUrl ?? string.Empty)">
                        Sign in
                    </a>
                </span>
            </form>

            <div class="flex items-center justify-between">
                <span class="w-full border-b border-stone-400"></span>
                <p class="text-stone-400 text-xs w-full text-center">Powered by Auth0</p>
                <span class="w-full border-b border-stone-400"></span>
            </div>
        </div>
    </div>
    <div class="relative flex items-center justify-center w-full min-h-screen bg-cover bg-center hidden lg:flex"
        style="background-image: url('/images/login-banner.png');">
        <div class="absolute inset-0 bg-black opacity-40"></div>

        <div class="absolute flex flex-col gap-3 bottom-30 left-0 right-0 p-5 max-w-[500px]">
            <span class="text-white text-4xl font-light">Nera Event Management System</span>
            <span class="text-white">Your gateway to comprehensive criminal justice information, empowering
                professionals, researchers, and the public with reliable data, expert insights, and the latest
                developments shaping law, policy, and reform across the justice system.</span>
        </div>
    </div>
</div>